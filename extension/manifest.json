{
  "manifest_version": 3,
  "name": "Productivity Hub — Save Bookmark",
  "version": "1.0.0",
  "description": "Save the current page to your Productivity Hub read-later list.",
  "permissions": ["activeTab", "contextMenus", "notifications", "scripting"],
  "host_permissions": ["http://localhost:5180/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Productivity Hub",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}
