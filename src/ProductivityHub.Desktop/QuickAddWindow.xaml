<Window x:Class="ProductivityHub.Desktop.QuickAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick capture" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" Topmost="True" ShowInTaskbar="False"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}">
    <StackPanel Margin="16">
        <TextBlock Text="⚡ Quick capture" Style="{StaticResource Heading}" Margin="0,0,0,4" />
        <TextBlock Text="Jot it down — it lands in your Inbox to sort later." Style="{StaticResource Muted}" Margin="0,0,0,10" />
        <TextBox x:Name="TextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalContentAlignment="Top" Tag="What's on your mind?" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="Hint" Style="{StaticResource Muted}" VerticalAlignment="Center"
                       Margin="0,0,12,0" Text="Ctrl+Enter to save · Esc to close" />
            <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button x:Name="SaveBtn" Content="Add to Inbox" Style="{StaticResource AccentButton}"
                    Click="Save_Click" />
        </StackPanel>
    </StackPanel>
</Window>
