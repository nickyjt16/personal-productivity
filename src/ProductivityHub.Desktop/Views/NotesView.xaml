<UserControl x:Class="ProductivityHub.Desktop.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <CheckBox x:Name="ArchivedCheck" Content="Show archived" VerticalAlignment="Center"
                          Margin="0,0,14,0" Click="ShowArchived_Changed" />
                <TextBlock Text="Project:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="FilterCombo" Width="160" SelectedValuePath="Id" SelectionChanged="Filter_Changed" />
            </StackPanel>
            <TextBlock Text="📝 Notes" Style="{StaticResource Heading}" Margin="0" />
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <Button DockPanel.Dock="Top" Content="+ New note" Click="New_Click" Margin="0,0,0,8" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListHost">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,0,6" Padding="10,8"
                                        Cursor="Hand" MouseLeftButtonUp="Select_Click">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Preview}" Style="{StaticResource Muted}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBox DockPanel.Dock="Top" x:Name="TitleBox" FontSize="16" Margin="0,0,0,8" Tag="Title" />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save" Style="{StaticResource AccentButton}" Click="Save_Click" />
                        <Button Content="🏷 Projects" Click="Projects_Click" Margin="8,0,0,0" />
                        <Button x:Name="ArchiveBtn" Content="Archive" Click="Archive_Click"
                                Margin="8,0,0,0" Visibility="Collapsed" />
                        <Button x:Name="DeleteBtn" Content="Delete" Style="{StaticResource DangerButton}"
                                Click="Delete_Click" Margin="8,0,0,0" Visibility="Collapsed" />
                    </StackPanel>
                    <TextBox x:Name="BodyBox" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Tag="Start writing…" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
