<UserControl x:Class="ProductivityHub.Desktop.Views.PomodoroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="🍅 Pomodoro" Style="{StaticResource Heading}" HorizontalAlignment="Center" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <RadioButton x:Name="FocusRadio" Content="Focus 25" IsChecked="True" GroupName="mode"
                         Checked="Mode_Changed" Margin="0,0,14,0" Foreground="{DynamicResource TextBrush}" />
            <RadioButton x:Name="BreakRadio" Content="Break 5" GroupName="mode"
                         Checked="Mode_Changed" Foreground="{DynamicResource TextBrush}" />
        </StackPanel>
        <TextBlock x:Name="TimeText" Text="25:00" FontSize="72" FontWeight="SemiBold" HorizontalAlignment="Center" />
        <ComboBox x:Name="TaskCombo" Width="300" Margin="0,12" SelectedValuePath="Id" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="StartBtn" Content="Start" Style="{StaticResource AccentButton}" Click="StartPause_Click" />
            <Button Content="Reset" Click="Reset_Click" Margin="8,0,0,0" />
            <Button Content="Pop out ⧉" Click="PopOut_Click" Margin="8,0,0,0" />
        </StackPanel>
        <TextBlock x:Name="SessionsText" Style="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,14,0,0" />
    </StackPanel>
</UserControl>
