<UserControl x:Class="ProductivityHub.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="540" HorizontalAlignment="Left">
            <TextBlock Text="⚙️ Settings" Style="{StaticResource Heading}" />

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Appearance" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                    <CheckBox x:Name="DarkCheck" Content="🌙  Dark mode" Click="Dark_Click" />
                    <CheckBox x:Name="TitlesCheck" Content="Auto-fetch page titles for bare URLs"
                              Click="Titles_Click" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Sections" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                    <StackPanel x:Name="SectionPanel" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Teams link-import folder" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                    <TextBlock Text="The OneDrive-synced folder your Teams flow drops link files into."
                               Style="{StaticResource Muted}" />
                    <DockPanel Margin="0,8,0,0">
                        <Button DockPanel.Dock="Right" Content="Browse…" Click="Browse_Click" Margin="8,0,0,0" />
                        <TextBox x:Name="FolderBox" />
                    </DockPanel>
                    <Button Content="Save folder" Click="SaveFolder_Click" HorizontalAlignment="Left" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Backup &amp; restore" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                    <TextBlock x:Name="BackupStatus" Style="{StaticResource Muted}" Visibility="Collapsed" Margin="0,0,0,6" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="⬇ Export backup" Click="Export_Click" />
                        <Button Content="⬆ Restore backup" Click="Import_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Data location (sync)" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                    <TextBlock Text="By default your data lives on this PC only. Point it at a OneDrive-synced folder to use it on more than one machine (both apps share it)."
                               Style="{StaticResource Muted}" />
                    <TextBlock x:Name="DbPathText" Margin="0,6,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Move to a folder…" Click="MoveDb_Click" />
                        <Button Content="Use default location" Click="DefaultDb_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="Danger zone" Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,6" />
                    <TextBlock Text="Permanently delete all data — this cannot be undone." Style="{StaticResource Muted}" />
                    <Button Content="Clear all data" Style="{StaticResource DangerButton}" Click="Clear_Click"
                            HorizontalAlignment="Left" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
