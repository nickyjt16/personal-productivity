<UserControl x:Class="ProductivityHub.Desktop.Views.SecretsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🔑 Secrets" Style="{StaticResource Heading}" />
        <TextBlock Grid.Row="1" Text="Track client secrets/keys and their expiry. Stored locally on this device."
                   Style="{StaticResource Muted}" Margin="0,0,0,12" />

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="NameBox" Width="220" Tag="Name (e.g. My app registration)" />
                    <TextBox x:Name="ClientBox" Width="220" Margin="8,0,0,0" Tag="Client ID (optional)" />
                    <DatePicker x:Name="ExpiresBox" Width="130" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="ValueBox" Width="360" Tag="Secret value (optional)" />
                    <Button x:Name="AddBtn" Content="Add" Style="{StaticResource AccentButton}" Click="Add_Click" Margin="8,0,0,0" />
                    <Button x:Name="CancelBtn" Content="Cancel" Click="Cancel_Click" Margin="8,0,0,0" Visibility="Collapsed" />
                </StackPanel>
                <TextBox x:Name="NotesBox" Margin="0,8,0,0" Tag="Notes (optional)" />
                <TextBlock Text="Who to inform when this changes (one per line)" Style="{StaticResource Muted}" Margin="0,8,0,2" />
                <TextBox x:Name="NotifyBox" Height="48" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                         Tag="e.g. jane@example.com, Platform Team, #secrets-channel" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,8">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{Binding BadgeBrush}" CornerRadius="9" Padding="8,2" Margin="3,0">
                                        <TextBlock Text="{Binding BadgeText}" Foreground="White" FontSize="11" />
                                    </Border>
                                    <Button Content="✎" Click="Edit_Click" Margin="3,0,0,0" Padding="7,4" />
                                    <Button Content="✕" Click="Delete_Click" Margin="3,0,0,0" Padding="7,4" />
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ClientId}" Style="{StaticResource Muted}" Margin="8,0,0,0"
                                                   Visibility="{Binding HasClientId, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ValueMasked}" Style="{StaticResource Muted}" ToolTip="{Binding Value}"
                                               Visibility="{Binding HasValue, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Style="{StaticResource Muted}">
                                        <Run Text="Expires " /><Run Text="{Binding ExpiresText, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Notes}" Style="{StaticResource Muted}"
                                               Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding NotifyText}" Style="{StaticResource Muted}"
                                               Visibility="{Binding HasNotify, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
