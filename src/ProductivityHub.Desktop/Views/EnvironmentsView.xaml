<UserControl x:Class="ProductivityHub.Desktop.Views.EnvironmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button x:Name="AddToggleBtn" DockPanel.Dock="Right" Content="＋ Add environment"
                    Style="{StaticResource AccentButton}" Click="ToggleAdd_Click" VerticalAlignment="Center" />
            <TextBlock Text="🌐 Environments" Style="{StaticResource Heading}" Margin="0" />
        </DockPanel>
        <TextBlock Grid.Row="1" Text="Power Platform / Dataverse environments — IDs, URLs, and per-environment setup."
                   Style="{StaticResource Muted}" Margin="0,0,0,12" />

        <Border x:Name="AddCard" Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="NameBox" Width="240" Tag="Name (e.g. Contoso - Dev)" />
                    <ComboBox x:Name="TypeBox" Width="120" Margin="8,0,0,0" />
                    <TextBox x:Name="RegionBox" Width="120" Margin="8,0,0,0" Tag="Region (optional)" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="EnvIdBox" Width="360" Tag="Environment ID (GUID)" />
                    <TextBox x:Name="UrlBox" Width="360" Margin="8,0,0,0" Tag="Org / environment URL" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="TenantBox" Width="360" Tag="Tenant ID (optional)" />
                    <TextBox x:Name="NotesBox" Width="360" Margin="8,0,0,0" Tag="Notes (optional)" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="AddBtn" Content="Add" Style="{StaticResource AccentButton}" Click="Add_Click" />
                    <Button x:Name="CancelBtn" Content="Cancel" Click="Cancel_Click" Margin="8,0,0,0" Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,10">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="✎" ToolTip="Edit" Click="Edit_Click" Margin="3,0,0,0" Padding="7,4" />
                                        <Button Content="✕" ToolTip="Delete" Click="Delete_Click" Margin="3,0,0,0" Padding="7,4" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                        <Border Background="{Binding TypeBrush}" CornerRadius="9" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeText}" Foreground="White" FontSize="11" />
                                        </Border>
                                        <TextBlock Text="{Binding Region}" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Visibility="{Binding HasRegion, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0"
                                           Visibility="{Binding HasEnvId, Converter={StaticResource BoolToVis}}">
                                    <Run Text="Environment ID: " /><Run Text="{Binding PpEnvironmentId, Mode=OneWay}" FontFamily="Consolas" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource Muted}"
                                           Visibility="{Binding HasUrl, Converter={StaticResource BoolToVis}}">
                                    <Run Text="URL: " /><Run Text="{Binding Url, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource Muted}"
                                           Visibility="{Binding HasTenant, Converter={StaticResource BoolToVis}}">
                                    <Run Text="Tenant ID: " /><Run Text="{Binding TenantId, Mode=OneWay}" FontFamily="Consolas" />
                                </TextBlock>
                                <TextBlock Text="{Binding Notes}" Style="{StaticResource Muted}"
                                           Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Maker portal ↗" Tag="{Binding MakerUrl}" Click="Link_Click" Margin="0,0,6,0" Padding="8,3"
                                            Visibility="{Binding HasMaker, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Admin centre ↗" Tag="{Binding AdminUrl}" Click="Link_Click" Margin="0,0,6,0" Padding="8,3"
                                            Visibility="{Binding HasMaker, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Open org ↗" Tag="{Binding Url}" Click="Link_Click" Margin="0,0,6,0" Padding="8,3"
                                            Visibility="{Binding HasUrl, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Dataverse API ↗" Tag="{Binding DataverseApi}" Click="Link_Click" Margin="0,0,6,0" Padding="8,3"
                                            Visibility="{Binding HasDataverse, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>

                                <DockPanel Margin="0,8,0,0">
                                    <Button DockPanel.Dock="Right" Content="Manage checklist" Click="Checklist_Click" Padding="8,3" />
                                    <TextBlock Text="{Binding ConfigSummary}" Style="{StaticResource Muted}" VerticalAlignment="Center" />
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
