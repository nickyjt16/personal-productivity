<UserControl x:Class="ProductivityHub.Desktop.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📁 Projects" Style="{StaticResource Heading}" />

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="NameBox" Width="240" Tag="Project name" />
                        <TextBox x:Name="DescBox" Width="300" Margin="8,0,0,0" Tag="Description (optional)" />
                        <Button x:Name="AddBtn" Content="Add" Style="{StaticResource AccentButton}" Click="Add_Click" Margin="8,0,0,0" />
                        <Button x:Name="CancelBtn" Content="Cancel" Click="CancelEdit_Click" Margin="8,0,0,0" Visibility="Collapsed" />
                    </StackPanel>
                    <WrapPanel x:Name="ColorPanel" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Show:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="FilterCombo" Width="140" SelectionChanged="Filter_Changed" />
            </StackPanel>

            <ItemsControl x:Name="CardsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="Card_Click">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="6" Background="{Binding ColorBrush}" CornerRadius="3" Margin="0,0,10,0" />
                                <Border DockPanel.Dock="Right" Background="{Binding StatusBrush}" CornerRadius="9" Padding="8,2"
                                        VerticalAlignment="Center" Height="22">
                                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Muted}"
                                               Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding CountsText}" Style="{StaticResource Muted}" />
                                    <ProgressBar Height="5" Maximum="100" Value="{Binding ProgressPct, Mode=OneWay}"
                                                 Margin="0,4,0,0" Width="200" HorizontalAlignment="Left"
                                                 Visibility="{Binding HasProgress, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="Detail" Style="{StaticResource Card}" Margin="0,12,0,0" Visibility="Collapsed">
                <StackPanel>
                    <DockPanel>
                        <TextBlock x:Name="DetailName" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button x:Name="StartBtn" Content="Start" Style="{StaticResource AccentButton}" Click="Start_Click" Margin="3,0" />
                            <Button x:Name="CompleteBtn" Content="Mark complete" Style="{StaticResource SuccessButton}" Click="Complete_Click" Margin="3,0" />
                            <Button x:Name="ArchiveBtn" Content="Archive" Click="Archive_Click" Margin="3,0" />
                            <Button x:Name="ReactivateBtn" Content="Reactivate" Click="Reactivate_Click" Margin="3,0" />
                            <Button Content="Edit" Click="EditProject_Click" Margin="3,0" />
                            <Button Content="Delete" Style="{StaticResource DangerButton}" Click="DeleteProject_Click" Margin="3,0" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="✅ Todos" Style="{StaticResource Muted}" Margin="0,0,0,4" />
                            <StackPanel x:Name="LinkedTodos" />
                            <ComboBox x:Name="AddTodoCombo" Margin="0,6,0,0"
                                      SelectedValuePath="Id" SelectionChanged="AddTodo_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="3,0">
                            <TextBlock Text="📝 Notes" Style="{StaticResource Muted}" Margin="0,0,0,4" />
                            <StackPanel x:Name="LinkedNotes" />
                            <ComboBox x:Name="AddNoteCombo" Margin="0,6,0,0"
                                      SelectedValuePath="Id" SelectionChanged="AddNote_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="3,0">
                            <TextBlock Text="🔖 Bookmarks" Style="{StaticResource Muted}" Margin="0,0,0,4" />
                            <StackPanel x:Name="LinkedBookmarks" />
                            <ComboBox x:Name="AddBookmarkCombo" Margin="0,6,0,0"
                                      SelectedValuePath="Id" SelectionChanged="AddBookmark_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="6,0,0,0">
                            <TextBlock Text="🔑 Secrets" Style="{StaticResource Muted}" Margin="0,0,0,4" />
                            <StackPanel x:Name="LinkedSecrets" />
                            <ComboBox x:Name="AddSecretCombo" Margin="0,6,0,0"
                                      SelectedValuePath="Id" SelectionChanged="AddSecret_Changed" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
