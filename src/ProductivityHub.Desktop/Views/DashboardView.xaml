<UserControl x:Class="ProductivityHub.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock x:Name="Greeting" Style="{StaticResource Heading}" />

            <UniformGrid Rows="1" Margin="0,0,0,14">
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Cursor="Hand"
                        Tag="todos" MouseLeftButtonUp="Card_Click" ToolTip="Go to Todos">
                    <StackPanel>
                        <TextBlock x:Name="OpenCount" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Open tasks" Style="{StaticResource Muted}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Cursor="Hand"
                        Tag="inbox" MouseLeftButtonUp="Card_Click" ToolTip="Go to Inbox">
                    <StackPanel>
                        <TextBlock x:Name="InboxCount" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="To triage" Style="{StaticResource Muted}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Cursor="Hand"
                        Tag="bookmarks" MouseLeftButtonUp="Card_Click" ToolTip="Go to Bookmarks">
                    <StackPanel>
                        <TextBlock x:Name="UnreadCount" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Unread links" Style="{StaticResource Muted}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Cursor="Hand"
                        Tag="secrets" MouseLeftButtonUp="Card_Click" ToolTip="Go to Secrets">
                    <StackPanel>
                        <TextBlock x:Name="ExpiringCount" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Secrets expiring (7d)" Style="{StaticResource Muted}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Today's tasks" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="OverdueBadge" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   Foreground="#DC3545" FontSize="12" Visibility="Collapsed" />
                    </DockPanel>
                    <TextBlock x:Name="NoTasks" Text="Nothing open. 🎉" Style="{StaticResource Muted}" Visibility="Collapsed" />
                    <ItemsControl x:Name="TasksHost">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsDone, Mode=OneWay}"
                                              Click="Toggle_Click" Margin="0,0,10,0" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Border Background="{Binding DueBrush}" CornerRadius="9" Padding="8,2" Margin="3,0"
                                                Visibility="{Binding HasDue, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding DueText}" Foreground="White" FontSize="11" />
                                        </Border>
                                        <Border Background="{Binding PriorityBrush}" CornerRadius="9" Padding="8,2" Margin="3,0">
                                            <TextBlock Text="{Binding PriorityText}" Foreground="White" FontSize="11" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Title}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
