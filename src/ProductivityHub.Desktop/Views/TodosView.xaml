<UserControl x:Class="ProductivityHub.Desktop.Views.TodosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <TextBlock Text="Project:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="FilterCombo" Width="160" SelectedValuePath="Id"
                          SelectionChanged="Filter_Changed" />
            </StackPanel>
            <TextBlock Text="✅ Todos" Style="{StaticResource Heading}" Margin="0" />
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TitleBox" Width="340" Tag="What needs doing?" />
                    <ComboBox x:Name="PriorityBox" Width="110" Margin="8,0,0,0" />
                    <DatePicker x:Name="DueBox" Width="130" Margin="8,0,0,0" />
                    <ComboBox x:Name="RepeatCombo" Width="110" Margin="8,0,0,0">
                        <ComboBoxItem Content="No repeat" Tag="None" IsSelected="True" />
                        <ComboBoxItem Content="Daily" Tag="Day" />
                        <ComboBoxItem Content="Weekly" Tag="Week" />
                        <ComboBoxItem Content="Monthly" Tag="Month" />
                    </ComboBox>
                    <Button x:Name="AddBtn" Content="Add" Style="{StaticResource AccentButton}"
                            Click="Add_Click" Margin="8,0,0,0" />
                    <Button x:Name="CancelBtn" Content="Cancel" Click="CancelEdit_Click"
                            Margin="8,0,0,0" Visibility="Collapsed" />
                </StackPanel>
                <TextBox x:Name="NotesBox" Margin="0,8,0,0" Height="44" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalContentAlignment="Top" Tag="Notes (optional)" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,8">
                            <DockPanel>
                                <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsDone, Mode=OneWay}"
                                          Click="Toggle_Click" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{Binding PriorityBrush}" CornerRadius="9" Padding="8,2" Margin="3,0">
                                        <TextBlock Text="{Binding PriorityText}" Foreground="White" FontSize="11" />
                                    </Border>
                                    <Border Background="{Binding DueBrush}" CornerRadius="9" Padding="8,2" Margin="3,0"
                                            Visibility="{Binding HasDue, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding DueText}" Foreground="White" FontSize="11" />
                                    </Border>
                                    <TextBlock Text="{Binding RecurText}" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="3,0"
                                               Visibility="{Binding HasRecur, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="🏷" ToolTip="Projects" Click="Projects_Click" Margin="3,0,0,0" Padding="7,4" />
                                    <Button Content="✎" ToolTip="Edit" Click="Edit_Click" Margin="3,0,0,0" Padding="7,4" />
                                    <Button Content="✕" ToolTip="Delete" Click="Delete_Click" Margin="3,0,0,0" Padding="7,4" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="14" />
                                    <TextBlock Text="{Binding Notes}" Style="{StaticResource Muted}"
                                               Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding ProjectTags}" Style="{StaticResource Muted}"
                                               Visibility="{Binding HasProjects, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
