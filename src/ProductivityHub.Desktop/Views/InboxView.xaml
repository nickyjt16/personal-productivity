<UserControl x:Class="ProductivityHub.Desktop.Views.InboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="📥 Inbox" Style="{StaticResource Heading}" />
        <TextBlock Grid.Row="1" Text="Dump a thought fast; triage it into a todo later."
                   Style="{StaticResource Muted}" Margin="0,0,0,12" />
        <DockPanel Grid.Row="2" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Capture" Style="{StaticResource AccentButton}"
                    Click="Capture_Click" Margin="8,0,0,0" />
            <TextBox x:Name="TextBox" KeyDown="TextBox_KeyDown" />
        </DockPanel>
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,8">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="→ Todo" Click="ToTodo_Click" Margin="3,0" Padding="7,4" />
                                    <Button Content="Done" Click="Process_Click" Margin="3,0" Padding="7,4" />
                                    <Button Content="✕" Click="Delete_Click" Margin="3,0" Padding="7,4" />
                                </StackPanel>
                                <TextBlock Text="{Binding Text}" VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
