<Window x:Class="ProductivityHub.Desktop.MasterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master password" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="ToolWindow" Background="{DynamicResource BgBrush}">
    <StackPanel Margin="18">
        <!-- First-run: set a password -->
        <StackPanel x:Name="SetupPanel">
            <TextBlock Text="🔒 Set a master password" Style="{StaticResource Heading}" Margin="0,0,0,6" />
            <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}" Margin="0,0,0,12"
                       Text="Your secret values are encrypted with this password. It is never stored anywhere and cannot be reset — if you forget it, you'll need to re-enter your secrets. The rest of the app is unaffected." />
            <TextBlock Text="Password" Margin="0,0,0,2" />
            <PasswordBox x:Name="Pwd1" />
            <TextBlock Text="Confirm password" Margin="0,10,0,2" />
            <PasswordBox x:Name="Pwd2" />
            <TextBlock Text="Hint (optional — shown when unlocking)" Margin="0,10,0,2" />
            <TextBox x:Name="HintBox" />
            <TextBlock x:Name="SetupError" Foreground="{DynamicResource DangerBrush}" Margin="0,8,0,0"
                       Visibility="Collapsed" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="SkipSetupBtn" Content="Not now" Click="Skip_Click" Margin="0,0,8,0" />
                <Button Content="Set password" Style="{StaticResource AccentButton}" Click="SetPassword_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Returning: unlock -->
        <StackPanel x:Name="UnlockPanel" Visibility="Collapsed">
            <TextBlock Text="🔒 Unlock secrets" Style="{StaticResource Heading}" Margin="0,0,0,6" />
            <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}" Margin="0,0,0,12"
                       Text="Enter your master password to view and edit secret values. You can skip and use the rest of the app normally." />
            <TextBlock Text="Password" Margin="0,0,0,2" />
            <PasswordBox x:Name="UnlockPwd" />
            <TextBlock x:Name="HintText" Style="{StaticResource Muted}" Margin="0,8,0,0"
                       Visibility="Collapsed" TextWrapping="Wrap" />
            <TextBlock x:Name="UnlockError" Foreground="{DynamicResource DangerBrush}" Margin="0,8,0,0"
                       Visibility="Collapsed" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="SkipUnlockBtn" Content="Skip for now" Click="Skip_Click" Margin="0,0,8,0" />
                <Button Content="Unlock" Style="{StaticResource AccentButton}" Click="Unlock_Click" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
