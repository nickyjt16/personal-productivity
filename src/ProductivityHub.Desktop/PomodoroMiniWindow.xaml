<Window x:Class="ProductivityHub.Desktop.PomodoroMiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro" Width="220" Height="170"
        Topmost="True" WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="TimeText" Text="25:00" FontSize="44" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="PauseBtn" Content="Pause" Click="Pause_Click" />
            <Button Content="Reset" Click="Reset_Click" Margin="6,0,0,0" />
            <Button Content="Reopen" Style="{StaticResource SuccessButton}" Click="Reopen_Click" Margin="6,0,0,0" />
        </StackPanel>
    </StackPanel>
</Window>
