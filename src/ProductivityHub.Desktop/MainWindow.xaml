<Window x:Class="ProductivityHub.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productivity Hub" Height="740" Width="1060"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="212" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel Margin="12">
                <TextBlock DockPanel.Dock="Top" Text="⚡ Productivity Hub"
                           Foreground="{DynamicResource SidebarTextBrush}"
                           FontSize="16" FontWeight="SemiBold" Margin="2,4,0,12" />
                <TextBox DockPanel.Dock="Top" x:Name="SearchBox" Margin="0,0,0,4"
                         KeyDown="SearchBox_KeyDown" />
                <TextBlock DockPanel.Dock="Top" Text="Search, then press Enter"
                           Foreground="{DynamicResource MutedBrush}" FontSize="10" Margin="2,0,0,12" />
                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavButton}" Click="Settings_Click">
                    <TextBlock Text="⚙  Settings" Foreground="White" />
                </Button>
                <StackPanel x:Name="NavPanel" />
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1" x:Name="MainContent" />
    </Grid>
</Window>
