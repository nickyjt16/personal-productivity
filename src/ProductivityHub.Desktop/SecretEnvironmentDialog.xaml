<Window x:Class="ProductivityHub.Desktop.SecretEnvironmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link environments" Height="420" Width="340"
        Background="{DynamicResource BgBrush}" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="Environments" Style="{StaticResource Heading}" />
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,0,0,8"
                   Text="Which environments does this secret apply to?" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource AccentButton}" Click="Save_Click" />
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="List" />
        </ScrollViewer>
    </DockPanel>
</Window>
